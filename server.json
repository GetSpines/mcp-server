{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.SuperAgentic/spines",
  "description": "Access book collections, reading lists, and bookshelf recognition from AI assistants.",
  "repository": {
    "url": "https://github.com/GetSpines/mcp-server",
    "source": "github"
  },
  "version": "1.0.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@spines/mcp-server",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your SPINES API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "SPINES_API_KEY"
        }
      ]
    }
  ]
}
